{
  "name": "spc-parser",
  "version": "1.0.0",
  "description": "Thermo Galactic GRAMS SPC files parser",
  "type": "module",
  "exports": {
    ".": "./lib/index.js"
  },
  "files": [
    "lib",
    "src"
  ],
  "scripts": {
    "build": "npm run tsc && cheminfo-build --entry lib/index.js --root SPCParser",
    "check-types": "tsc --noEmit",
    "clean": "rimraf lib lib-esm",
    "eslint": "eslint src",
    "eslint-fix": "npm run eslint -- --fix",
    "prepack": "npm run tsc",
    "prettier": "prettier --check src",
    "prettier-write": "prettier --write src",
    "test": "npm run test-only && npm run check-types && npm run eslint && npm run prettier",
    "test-only": "vitest run --coverage",
    "tsc": "npm run clean && npm run tsc-build",
    "tsc-build": "tsc --project tsconfig.build.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cheminfo/spc-parser.git"
  },
  "keywords": [],
  "author": "Benjamin Yiu",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/cheminfo/spc-parser/issues"
  },
  "homepage": "https://github.com/cheminfo/spc-parser#readme",
  "dependencies": {
    "cheminfo-types": "^1.10.0",
    "iobuffer": "^5.3.2",
    "ml-spectra-processing": "^14.22.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@zakodium/tsconfig": "^1.0.2",
    "cheminfo-build": "^1.3.2",
    "eslint": "^9.27.0",
    "eslint-config-cheminfo-typescript": "^21.1.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "typescript": "~5.9.3",
    "vitest": "^4.0.18"
  }
}
